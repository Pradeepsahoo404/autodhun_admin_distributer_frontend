# Public API base URL of the Express backend
NEXT_PUBLIC_API_URL=http://localhost:5000/api

# NextAuth — MUST match the exact URL you open in the browser (no trailing slash)
# On Render use a REAL random secret: openssl rand -base64 32
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=replace_with_openssl_rand_base64_32_output

# Google OAuth (same Web client as the backend)
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your_google_client_id

# ---- Google Cloud Console (OAuth 2.0 Web client) ----
# Authorized JavaScript origins:
#   http://localhost:3000
#   https://autodhun-admin-distributer-frontend.onrender.com
#
# Authorized redirect URIs (NextAuth only — do NOT use site root alone):
#   http://localhost:3000/api/auth/callback/google
#   https://autodhun-admin-distributer-frontend.onrender.com/api/auth/callback/google
# After OAuth, the app sends users to /auth/google-complete (no extra Google Console entry needed).
#
# OAuth consent screen → Scopes: openid, email, profile
# If app is in Testing mode, add your Google account under Test users
#
# ---- Render production (frontend service) ----
# NEXTAUTH_URL=https://autodhun-admin-distributer-frontend.onrender.com
# NEXT_PUBLIC_API_URL=https://autodhun-admin-distributer-backend.onrender.com/api
