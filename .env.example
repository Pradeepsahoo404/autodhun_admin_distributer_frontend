# Public API base URL of the Express backend
NEXT_PUBLIC_API_URL=http://localhost:5000/api

# NextAuth — must match the URL you open in the browser (no trailing slash)
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=generate_a_strong_random_secret

# Google OAuth (same Web client as the backend)
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your_google_client_id

# Google Cloud Console → APIs & Services → Credentials → OAuth 2.0 Client (Web)
# Authorized JavaScript origins:
#   http://localhost:3000
# Authorized redirect URIs (required — do NOT use the origin alone):
#   http://localhost:3000/api/auth/callback/google
#
# OAuth consent screen → Scopes: openid, email, profile (profile includes name + photo)
# If app is in Testing mode, add your Google account under Test users
